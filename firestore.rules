rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Messages: anyone authenticated can read active messages; only admin writes
    match /messages/{messageId} {
      allow read: if request.auth != null && resource.data.active == true;
      allow write: if false; // managed via Firebase Admin SDK / console
    }

    // Users: each user can only read and write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
